@using Tldraw.Blazor.Core.Editor
@using Tldraw.Blazor.Core.Store
@using Tldraw.Blazor.Core

@if (_selectedShapes.Count > 0)
{
    <div class="style-panel">
        <div class="style-section">
            <label>Stroke</label>
            <div class="color-row">
                @foreach (var color in _strokeColors)
                {
                    <button class="color-swatch @(CurrentColor == color ? "active" : "")"
                            style="background: @color"
                            @onclick='() => SetColor(color)'
                            title="@color">
                    </button>
                }
            </div>
        </div>

        <div class="style-section">
            <label>Fill</label>
            <div class="color-row">
                <button class="color-swatch @(CurrentFill == FillConstants.None ? "active" : "")"
                        style="background: #fff; border: 2px dashed #ccc;"
                        @onclick='() => SetFill(FillConstants.None)'
                        title="No fill">
                    <span style="font-size: 10px; color: #999;">✕</span>
                </button>
                @foreach (var color in _fillColors)
                {
                    <button class="color-swatch @(CurrentFill == color ? "active" : "")"
                            style="background: @color"
                            @onclick='() => SetFill(color)'
                            title="@color">
                    </button>
                }
            </div>
        </div>

        <div class="style-section">
            <label>Stroke Width: @CurrentStrokeWidth.ToString("F1")</label>
            <input type="range" min="0.5" max="10" step="0.5"
                   value="@CurrentStrokeWidth"
                   @oninput="OnStrokeWidthChanged" />
        </div>

        <div class="style-section">
            <label>Opacity: @($"{CurrentOpacity:P0}")</label>
            <input type="range" min="0" max="1" step="0.05"
                   value="@CurrentOpacity"
                   @oninput="OnOpacityChanged" />
        </div>

        <div class="style-section">
            <label>Dash</label>
            <div class="dash-row">
                <button class="dash-btn @(CurrentDash == DashPattern.Solid ? "active" : "")"
                        @onclick='() => SetDash(DashPattern.Solid)'>━</button>
                <button class="dash-btn @(CurrentDash == DashPattern.Dashed ? "active" : "")"
                        @onclick='() => SetDash(DashPattern.Dashed)'>┅</button>
                <button class="dash-btn @(CurrentDash == DashPattern.Dotted ? "active" : "")"
                        @onclick='() => SetDash(DashPattern.Dotted)'>┈</button>
            </div>
        </div>

        @if (HasGeoShapes)
        {
            <div class="style-section">
                <label>Radius: @CurrentBorderRadius.ToString("F0")</label>
                <input type="range" min="0" max="50" step="1"
                       value="@CurrentBorderRadius"
                       @oninput="OnBorderRadiusChanged" />
            </div>
        }

        @if (HasTextShapes)
        {
            <div class="style-section">
                <label>Font Size: @CurrentFontSize.ToString("F0")</label>
                <input type="range" min="8" max="72" step="1"
                       value="@CurrentFontSize"
                       @oninput="OnFontSizeChanged" />
            </div>
        }
    </div>
}

@code {
    [Parameter] public Editor Editor { get; set; } = null!;

    private List<TLShapeRecord> _selectedShapes = new();

    private string[] _strokeColors = new[]
    {
        "#1e1e1e", "#ef4444", "#f97316", "#eab308",
        "#22c55e", "#3b82f6", "#8b5cf6", "#ec4899",
    };

    private string[] _fillColors = new[]
    {
        "#FEE2E2", "#FFEDD5", "#FEF9C3", "#DCFCE7",
        "#DBEAFE", "#EDE9FE", "#FCE7F3", "#F5F5F5",
    };

    private string CurrentColor => _selectedShapes.FirstOrDefault()?.Style.Color ?? "#1e1e1e";
    private string CurrentFill => _selectedShapes.FirstOrDefault()?.Style.Fill ?? FillConstants.None;
    private double CurrentStrokeWidth => (double)(_selectedShapes.FirstOrDefault()?.Style.StrokeWidth ?? new PositiveDouble(2));
    private double CurrentOpacity => (double)(_selectedShapes.FirstOrDefault()?.Style.Opacity ?? UnitInterval.One);
    private DashPattern CurrentDash => _selectedShapes.FirstOrDefault()?.Style.DashPattern ?? DashPattern.Solid;
    private double CurrentBorderRadius => (double)(_selectedShapes.FirstOrDefault()?.Style.BorderRadius ?? NonNegativeDouble.Zero);
    private double CurrentFontSize => (double)(_selectedShapes.FirstOrDefault()?.Style.FontSize ?? new PositiveDouble(16));
    private bool HasGeoShapes => _selectedShapes.Any(s => s.ShapeType == "geo");
    private bool HasTextShapes => _selectedShapes.Any(s => s.ShapeType is "text" or "note");

    protected override void OnInitialized()
    {
        Editor.Selection.SelectionChanged += OnSelectionChanged;
        Editor.StateChanged += OnStateChanged;
        RefreshShapes();
    }

    private void OnSelectionChanged()
    {
        RefreshShapes();
        InvokeAsync(StateHasChanged);
    }

    private void OnStateChanged()
    {
        RefreshShapes();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshShapes()
    {
        _selectedShapes = Editor.Selection.GetSelectedShapes(Editor.Store);
    }

    private void SetColor(string color)
    {
        Editor.PushUndo();
        foreach (var shape in _selectedShapes)
            shape.Style.Color = new HexColor(color);
        Editor.Invalidate();
    }

    private void SetFill(string fill)
    {
        Editor.PushUndo();
        foreach (var shape in _selectedShapes)
            shape.Style.Fill = new HexColor(fill);
        Editor.Invalidate();
    }

    private void OnStrokeWidthChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
        {
            Editor.PushUndo();
            foreach (var shape in _selectedShapes)
                shape.Style.StrokeWidth = new PositiveDouble(val);
            Editor.Invalidate();
        }
    }

    private void OnOpacityChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
        {
            Editor.PushUndo();
            foreach (var shape in _selectedShapes)
                shape.Style.Opacity = new UnitInterval(val);
            Editor.Invalidate();
        }
    }

    private void SetDash(DashPattern dash)
    {
        Editor.PushUndo();
        foreach (var shape in _selectedShapes)
            shape.Style.DashPattern = dash;
        Editor.Invalidate();
    }

    private void OnBorderRadiusChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
        {
            Editor.PushUndo();
            foreach (var shape in _selectedShapes)
                shape.Style.BorderRadius = new NonNegativeDouble(val);
            Editor.Invalidate();
        }
    }

    private void OnFontSizeChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
        {
            Editor.PushUndo();
            foreach (var shape in _selectedShapes)
            {
                shape.Style.FontSize = new PositiveDouble(val);
                if (shape.Props is TLTextProps textProps)
                    textProps.FontSize = new PositiveDouble(val);
            }
            Editor.Invalidate();
        }
    }

    public void Dispose()
    {
        Editor.Selection.SelectionChanged -= OnSelectionChanged;
        Editor.StateChanged -= OnStateChanged;
    }
}
