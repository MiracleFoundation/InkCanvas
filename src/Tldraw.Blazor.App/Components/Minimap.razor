@using Tldraw.Blazor.Core.Editor
@using Tldraw.Blazor.Core.Store
@using SkiaSharp
@using SkiaSharp.Views.Blazor

<div class="minimap-container">
    <div class="minimap-header">Map</div>
    <div class="minimap-canvas">
        <SKCanvasView OnPaintSurface="OnPaint" IgnorePixelScaling="false"
                      style="width: 100%; height: 100%;" />
    </div>
</div>

@code {
    [Parameter] public Editor Editor { get; set; } = null!;

    private const int MapWidth = 180;
    private const int MapHeight = 120;

    protected override void OnInitialized()
    {
        Editor.StateChanged += () => InvokeAsync(StateHasChanged);
    }

    private void OnPaint(SKPaintSurfaceEventArgs args)
    {
        var canvas = args.Surface.Canvas;
        var info = args.Info;
        canvas.Clear(new SKColor(0xFA, 0xFA, 0xFA));

        var shapes = Editor.Store.GetAllShapes();
        if (shapes.Count == 0) return;

        // Compute bounds of all shapes
        float minX = float.MaxValue, minY = float.MaxValue;
        float maxX = float.MinValue, maxY = float.MinValue;

        foreach (var shape in shapes)
        {
            var util = Editor.ShapeUtils.Get(shape.ShapeType);
            if (util == null) continue;
            var bounds = util.GetBounds(shape);
            minX = Math.Min(minX, bounds.Left);
            minY = Math.Min(minY, bounds.Top);
            maxX = Math.Max(maxX, bounds.Right);
            maxY = Math.Max(maxY, bounds.Bottom);
        }

        float contentW = maxX - minX;
        float contentH = maxY - minY;
        if (contentW <= 0 || contentH <= 0) return;

        float scale = Math.Min(info.Width / contentW, info.Height / contentH) * 0.9f;
        float offsetX = (info.Width - contentW * scale) / 2 - minX * scale;
        float offsetY = (info.Height - contentH * scale) / 2 - minY * scale;

        canvas.Save();
        canvas.Translate(offsetX, offsetY);
        canvas.Scale(scale);

        // Draw shapes as simplified rectangles
        using var shapePaint = new SKPaint
        {
            Style = SKPaintStyle.Fill,
            Color = new SKColor(0xCC, 0xCC, 0xCC),
            IsAntialias = true,
        };

        foreach (var shape in shapes.Where(s => !s.IsHidden))
        {
            var util = Editor.ShapeUtils.Get(shape.ShapeType);
            if (util == null) continue;
            var bounds = util.GetBounds(shape);
            canvas.DrawRect(bounds, shapePaint);
        }

        // Draw viewport rectangle
        var viewport = Editor.Camera.GetWorldBounds();
        using var viewportPaint = new SKPaint
        {
            Style = SKPaintStyle.Stroke,
            Color = new SKColor(0x00, 0x78, 0xD4, 180),
            StrokeWidth = 2f / scale,
            IsAntialias = true,
        };
        canvas.DrawRect(new SKRect(
            (float)viewport.Left, (float)viewport.Top,
            (float)viewport.Right, (float)viewport.Bottom), viewportPaint);

        canvas.Restore();
    }
}
