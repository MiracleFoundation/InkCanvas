@page "/docs/shortcuts"

<PageTitle>Keyboard Shortcuts - Tldraw.Blazor Docs</PageTitle>

<div class="docs-content">
    <h1>Keyboard Shortcuts</h1>
    <p class="docs-lead">All available keyboard shortcuts for Tldraw.Blazor.</p>

    <h2 id="tools">
        Tool Switching
        <a class="docs-anchor" href="#tools">#</a>
    </h2>

    <ApiTable>
        <ApiRow Name="V" Type="key" Default="" Desc="Select tool" />
        <ApiRow Name="D" Type="key" Default="" Desc="Draw tool" />
        <ApiRow Name="G" Type="key" Default="" Desc="Geo tool" />
        <ApiRow Name="H" Type="key" Default="" Desc="Hand tool" />
        <ApiRow Name="T" Type="key" Default="" Desc="Text tool" />
        <ApiRow Name="A" Type="key" Default="" Desc="Arrow tool" />
        <ApiRow Name="E" Type="key" Default="" Desc="Eraser tool" />
        <ApiRow Name="Space+Drag" Type="key" Default="" Desc="Pan (any tool)" />
    </ApiTable>

    <h2 id="editing">
        Editing
        <a class="docs-anchor" href="#editing">#</a>
    </h2>

    <ApiTable>
        <ApiRow Name="Ctrl+Z" Type="shortcut" Default="" Desc="Undo" />
        <ApiRow Name="Ctrl+Y" Type="shortcut" Default="" Desc="Redo" />
        <ApiRow Name="Ctrl+Shift+Z" Type="shortcut" Default="" Desc="Redo (alternative)" />
        <ApiRow Name="Ctrl+C" Type="shortcut" Default="" Desc="Copy selected" />
        <ApiRow Name="Ctrl+V" Type="shortcut" Default="" Desc="Paste" />
        <ApiRow Name="Ctrl+X" Type="shortcut" Default="" Desc="Cut selected" />
        <ApiRow Name="Ctrl+A" Type="shortcut" Default="" Desc="Select all" />
        <ApiRow Name="Del / Backspace" Type="key" Default="" Desc="Delete selected" />
        <ApiRow Name="Escape" Type="key" Default="" Desc="Deselect / Cancel" />
    </ApiTable>

    <h2 id="layout">
        Layout
        <a class="docs-anchor" href="#layout">#</a>
    </h2>

    <ApiTable>
        <ApiRow Name="Ctrl+G" Type="shortcut" Default="" Desc="Group selected" />
        <ApiRow Name="Ctrl+Shift+G" Type="shortcut" Default="" Desc="Ungroup selected" />
    </ApiTable>

    <h2 id="interaction">
        Mouse / Touch
        <a class="docs-anchor" href="#interaction">#</a>
    </h2>

    <ApiTable>
        <ApiRow Name="Click" Type="mouse" Default="" Desc="Select shape" />
        <ApiRow Name="Shift+Click" Type="mouse" Default="" Desc="Toggle in selection" />
        <ApiRow Name="Drag (empty)" Type="mouse" Default="" Desc="Rubber-band selection" />
        <ApiRow Name="Drag (shape)" Type="mouse" Default="" Desc="Move selected" />
        <ApiRow Name="Drag (handle)" Type="mouse" Default="" Desc="Resize" />
        <ApiRow Name="Drag (rotation)" Type="mouse" Default="" Desc="Rotate" />
        <ApiRow Name="Shift+Drag" Type="mouse" Default="" Desc="Constrain proportions" />
        <ApiRow Name="Alt+Drag" Type="mouse" Default="" Desc="Resize from center" />
        <ApiRow Name="Scroll" Type="mouse" Default="" Desc="Zoom at cursor" />
        <ApiRow Name="Right-click" Type="mouse" Default="" Desc="Context menu" />
        <ApiRow Name="Double-click" Type="mouse" Default="" Desc="Edit text" />
        <ApiRow Name="Pinch" Type="touch" Default="" Desc="Zoom" />
        <ApiRow Name="Two-finger drag" Type="touch" Default="" Desc="Pan" />
    </ApiTable>
</div>
