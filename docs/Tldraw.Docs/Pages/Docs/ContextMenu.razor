@page "/docs/context-menu"

<PageTitle>Context Menu - Tldraw.Blazor Docs</PageTitle>

<div class="docs-content">
    <h1>Context Menu</h1>
    <p class="docs-lead">Right-click on the canvas to access context-sensitive actions.</p>

    <h2 id="with-selection">
        With Selection
        <a class="docs-anchor" href="#with-selection">#</a>
    </h2>
    <ul>
        <li>📋 Copy, ✂️ Cut, 📄 Paste, 🗑️ Delete</li>
        <li>⬆️ Bring to Front, ⬇️ Send to Back, 🔼 Bring Forward, 🔽 Send Backward</li>
        <li>📦 Group (Ctrl+G), 📭 Ungroup (Ctrl+Shift+G)</li>
        <li>⫷ Alignment (Left/Center/Right/Top/Middle/Bottom)</li>
        <li>↔️ Distribution (Horizontal/Vertical)</li>
    </ul>

    <h2 id="without-selection">
        Without Selection
        <a class="docs-anchor" href="#without-selection">#</a>
    </h2>
    <ul>
        <li>📄 Paste</li>
        <li>Select All (Ctrl+A)</li>
        <li>↩️ Undo, ↪️ Redo</li>
    </ul>
</div>
