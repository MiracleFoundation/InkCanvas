@page "/docs/camera"

<PageTitle>Camera - Tldraw.Blazor Docs</PageTitle>

<div class="docs-content">
    <h1>Camera</h1>
    <p class="docs-lead">The <code>Camera</code> manages viewport position and zoom level, with coordinate conversion between screen and world space.</p>

    <h2 id="properties">
        Properties
        <a class="docs-anchor" href="#properties">#</a>
    </h2>

    <ApiTable>
        <ApiRow Name="Position" Type="SKPointd" Default="0, 0" Desc="Camera position in world space (top-left corner)" />
        <ApiRow Name="Zoom" Type="double" Default="1.0" Desc="Zoom level (clamped 0.05–20.0)" />
        <ApiRow Name="ViewportSize" Type="SKSize" Default="800x600" Desc="Viewport size in screen pixels" />
    </ApiTable>

    <h2 id="methods">
        Methods
        <a class="docs-anchor" href="#methods">#</a>
    </h2>

    <CodeBlock Language="csharp" Code="@(@"// Pan by screen delta
editor.Camera.Pan(dx, dy);

// Zoom at specific screen point (cursor stays fixed)
editor.Camera.ZoomAt(screenPoint, delta);

// Coordinate conversion
var world = editor.Camera.ScreenToWorld(screenX, screenY);
var screen = editor.Camera.WorldToScreen(worldX, worldY);

// Get visible world bounds
var bounds = editor.Camera.GetWorldBounds(); // SKRectd

// Get transform matrix for rendering
var matrix = editor.Camera.GetTransformMatrix(); // SKMatrix

// Reset to default
editor.Camera.Reset();")" />

    <h2 id="coordinates">
        Coordinate Systems
        <a class="docs-anchor" href="#coordinates">#</a>
    </h2>
    <ul>
        <li><strong>Screen coordinates</strong> — pixels on screen (origin = top-left of canvas element)</li>
        <li><strong>World coordinates</strong> — coordinates in the infinite canvas (origin = 0,0 in world space)</li>
    </ul>
    <p>The camera converts between these two systems based on its <code>Position</code> (pan offset) and <code>Zoom</code> level.</p>
</div>
