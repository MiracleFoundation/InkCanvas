<section class="hero">
    <div class="hero__content">
        <div class="hero__eyebrow">Open Source · Blazor + SkiaSharp</div>
        <h1 class="hero__title">Build infinite canvas apps in Blazor</h1>
        <p class="hero__subtitle">
            A high-performance whiteboard SDK powered by SkiaSharp. Pure C# engine with shape types, tools, arrow bindings, undo/redo, and touch support.
        </p>
        <div class="hero__actions">
            <a href="docs" class="btn btn--dark">
                Read the Docs
                <span class="btn__arrow">&rarr;</span>
            </a>
            <a href="docs/quick-start" class="btn btn--ghost">
                Quick Start
            </a>
        </div>
        <div class="hero__install">
            <span class="prompt">$</span>
            <code>git clone https://github.com/your-repo/Tldraw.Blazor.git</code>
            <button class="hero__copy" onclick="navigator.clipboard.writeText('git clone https://github.com/your-repo/Tldraw.Blazor.git')">Copy</button>
        </div>
    </div>
    <div class="hero__demo">
        <div class="code-card">
            <div class="code-card__header">
                <div class="code-card__dots">
                    <span class="code-card__dot"></span>
                    <span class="code-card__dot"></span>
                    <span class="code-card__dot"></span>
                </div>
                <div class="code-card__tabs">
                    <span class="code-card__tab active">Home.razor</span>
                    <span class="code-card__tab">Editor.cs</span>
                </div>
            </div>
            <pre class="code-card__body"><code><span class="ck">@@using</span> Tldraw.Blazor.Skia
<span class="ck">@@using</span> Tldraw.Blazor.Core.Editor

&lt;<span class="cTag">TldrawCanvas</span> <span class="cAttr">Editor</span>=<span class="cs">"_editor"</span> /&gt;

<span class="ck">@@code</span> {
    <span class="ck">private</span> <span class="ct">Editor</span> _editor = <span class="ck">new</span>();

    <span class="ck">protected override void</span> <span class="cf">OnInitialized</span>()
    {
        <span class="cc">// Create shapes programmatically</span>
        _editor.<span class="cf">CreateShape</span>(<span class="cs">"geo"</span>, <span class="cn">100</span>, <span class="cn">100</span>);
        <span class="ck">var</span> rect = _editor.Store
            .<span class="cf">GetAllShapes</span>().<span class="cf">Last</span>();
        rect.Style.Fill = <span class="cs">"#E3F2FD"</span>;
    }
}</code></pre>
        </div>
    </div>
</section>

