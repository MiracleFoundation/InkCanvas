@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="docs-layout">
    <aside class="docs-sidebar @(sidebarOpen ? "open" : "")">
        <div class="docs-sidebar__header">
            <a href="./" class="docs-sidebar__logo">
                <span class="docs-sidebar__logo-icon">🎨</span>
                <span class="docs-sidebar__logo-text">Tldraw.Blazor</span>
            </a>
            <span class="docs-sidebar__version">v1.0</span>
        </div>

        <nav class="docs-sidebar__nav">
            <div class="docs-sidebar__group">
                <a href="demo" class="docs-sidebar__link" style="font-weight: 600; color: var(--docs-accent);">🎨 Live Demo</a>
            </div>

            <div class="docs-sidebar__group">
                <div class="docs-sidebar__group-title">Getting Started</div>
                <NavLink class="docs-sidebar__link" href="docs" Match="NavLinkMatch.All">Introduction</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/quick-start">Quick Start</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/architecture">Architecture</NavLink>
            </div>

            <div class="docs-sidebar__group">
                <div class="docs-sidebar__group-title">Core Concepts</div>
                <NavLink class="docs-sidebar__link" href="docs/editor">Editor</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/store">Store & Records</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/shapes">Shapes</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/tools">Tools</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/camera">Camera</NavLink>
            </div>

            <div class="docs-sidebar__group">
                <div class="docs-sidebar__group-title">Features</div>
                <NavLink class="docs-sidebar__link" href="docs/selection">Selection & Transform</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/arrows">Arrow System</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/undo">Undo / Redo</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/clipboard">Clipboard</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/layout">Layout & Composition</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/styling">Styling</NavLink>
            </div>

            <div class="docs-sidebar__group">
                <div class="docs-sidebar__group-title">UI Components</div>
                <NavLink class="docs-sidebar__link" href="docs/toolbar">Toolbar</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/context-menu">Context Menu</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/dark-mode">Dark Mode</NavLink>
            </div>

            <div class="docs-sidebar__group">
                <div class="docs-sidebar__group-title">Data</div>
                <NavLink class="docs-sidebar__link" href="docs/persistence">Persistence</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/export">Export / Import</NavLink>
            </div>

            <div class="docs-sidebar__group">
                <div class="docs-sidebar__group-title">Reference</div>
                <NavLink class="docs-sidebar__link" href="docs/shortcuts">Keyboard Shortcuts</NavLink>
                <NavLink class="docs-sidebar__link" href="docs/api">API Reference</NavLink>
            </div>
        </nav>

        <div class="docs-sidebar__footer">
            <a href="https://github.com/your-repo/Tldraw.Blazor" target="_blank">GitHub</a>
            <span>&bull;</span>
            <span>MIT License</span>
            <button class="docs-theme-toggle" onclick="toggleDocsTheme()" aria-label="Toggle theme">🌙</button>
        </div>
    </aside>

    <button class="docs-sidebar-toggle" @onclick="ToggleSidebar">
        <span></span><span></span><span></span>
    </button>

    @if (sidebarOpen)
    {
        <div class="docs-sidebar-overlay visible" @onclick="ToggleSidebar"></div>
    }

    <main class="docs-main">
        <div class="docs-main__content">
            @Body
        </div>
    </main>
</div>

@code {
    private bool sidebarOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!OperatingSystem.IsBrowser()) return;

        if (firstRender)
            await Task.Delay(200);

        try
        {
            await JS.InvokeVoidAsync("TldrawDocs.initCopyButtons");
        }
        catch (JSException) { }
        catch (JSDisconnectedException) { }
    }

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }
}
