@page "/demo"
@layout DemoLayout
@using InkCanvas.Canvas
@using InkCanvas.Core.Editor
@using InkCanvas.Core.Store
@using InkCanvas.Core
@using InkCanvas.Docs.Components
@inject IJSRuntime JS

<PageTitle>tldraw – Demo</PageTitle>

<div style="width: 100%; height: 100%; display: flex; flex-direction: column;">

    <!-- Toolbar -->
    <div style="display: flex; align-items: center; gap: 4px; padding: 6px 12px;
                background: #fff; border-bottom: 1px solid #e0e0e0; flex-shrink: 0;">

        <a href="docs" style="font-weight: 700; font-size: 15px; color: #111; text-decoration: none; margin-right: 12px;">🎨 tldraw</a>

        <button class="tool-btn @ToolBtnClass("select")" @onclick='() => SetTool("select")'
                title="Select (V)">▢ Select</button>
        <button class="tool-btn @ToolBtnClass("hand")" @onclick='() => SetTool("hand")'
                title="Hand (H)">✋ Hand</button>
        <button class="tool-btn @ToolBtnClass("draw")" @onclick='() => SetTool("draw")'
                title="Draw (D)">✏️ Draw</button>

        <span style="margin: 0 4px; color: #ccc;">|</span>

        <button class="tool-btn @ToolBtnClass("geo:rectangle")" @onclick='() => SetGeoTool("rectangle")'
                title="Rectangle">▭ Rect</button>
        <button class="tool-btn @ToolBtnClass("geo:ellipse")" @onclick='() => SetGeoTool("ellipse")'
                title="Ellipse">⬭ Ellipse</button>
        <button class="tool-btn @ToolBtnClass("geo:diamond")" @onclick='() => SetGeoTool("diamond")'
                title="Diamond">◇ Diamond</button>
        <button class="tool-btn @ToolBtnClass("geo:star")" @onclick='() => SetGeoTool("star")'
                title="Star">⭐ Star</button>
        <button class="tool-btn @ToolBtnClass("geo:hexagon")" @onclick='() => SetGeoTool("hexagon")'
                title="Hexagon">⬡ Hex</button>
        <button class="tool-btn @ToolBtnClass("geo:triangle")" @onclick='() => SetGeoTool("triangle")'
                title="Triangle">△ Tri</button>

        <span style="margin: 0 4px; color: #ccc;">|</span>

        <button class="tool-btn @ToolBtnClass("text")" @onclick='() => SetTool("text")'
                title="Text (T)">𝐓 Text</button>
        <button class="tool-btn @ToolBtnClass("arrow")" @onclick='() => SetTool("arrow")'
                title="Arrow (A)">➜ Arrow</button>
        <button class="tool-btn @ToolBtnClass("eraser")" @onclick='() => SetTool("eraser")'
                title="Eraser (E)">🧹 Erase</button>

        <span style="margin: 0 4px; color: #ccc;">|</span>

        <button class="tool-btn" @onclick="ExportPng" title="Export PNG">🖼️ PNG</button>
        <button class="tool-btn" @onclick="ExportJson" title="Export JSON">💾 JSON</button>

        <span style="flex: 1;"></span>

        <span style="font-size: 12px; color: #888;">
            <b>@_editor.ActiveTool.Id</b> &nbsp;|&nbsp;
            @(_autoSaveStatus)
        </span>
    </div>

    <!-- Canvas -->
    <div style="flex: 1; min-height: 0; position: relative;"
         @oncontextmenu="OnContextMenu" @oncontextmenu:preventDefault>
        <TldrawCanvas Editor="_editor" />
        <StylePanel Editor="_editor" />
        <ContextMenu @ref="_contextMenu" Editor="_editor" />
        <Minimap Editor="_editor" />
    </div>
</div>

<style>
    .tool-btn {
        padding: 4px 10px;
        border: 1px solid transparent;
        border-radius: 6px;
        background: transparent;
        cursor: pointer;
        font-size: 13px;
        color: #444;
        transition: all 0.15s;
    }
    .tool-btn:hover { background: #f0f0f0; }
    .tool-btn.active {
        background: #E3F2FD;
        border-color: #1565C0;
        color: #1565C0;
        font-weight: 600;
    }
</style>

@code {
    private Editor _editor = new();
    private string _activeGeoType = "rectangle";
    private ContextMenu? _contextMenu;
    private string _autoSaveStatus = "idle";
    private System.Threading.Timer? _autoSaveTimer;

    private string ToolBtnClass(string toolKey)
    {
        var currentTool = _editor.ActiveTool.Id;
        if (toolKey.StartsWith("geo:"))
        {
            var geoType = toolKey[4..];
            return currentTool == StateId.Geo && _activeGeoType == geoType ? "active" : "";
        }
        if (Enum.TryParse<StateId>(toolKey, true, out var id))
            return currentTool == id ? "active" : "";
        return "";
    }

    private void SetTool(string toolId)
    {
        if (Enum.TryParse<StateId>(toolId, true, out var id))
            _editor.SetActiveTool(id);
        // SetActiveTool already calls Invalidate() → StateChanged → StateHasChanged
    }

    private void SetGeoTool(string geoType)
    {
        _activeGeoType = geoType;
        var geoTool = _editor.GetTool(StateId.Geo) as InkCanvas.Core.Tools.GeoTool;
        if (geoTool != null && Enum.TryParse<GeoVariant>(geoType, true, out var variant))
            geoTool.GeoType = variant;
        _editor.SetActiveTool(StateId.Geo);
        // SetActiveTool already calls Invalidate() → StateChanged → StateHasChanged
    }

    private void OnContextMenu(MouseEventArgs e)
    {
        _contextMenu?.Show(e.ClientX, e.ClientY);
    }

    protected override async Task OnInitializedAsync()
    {
        _editor.StateChanged += OnEditorStateChanged;

        await LoadFromStorage();

        _autoSaveTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () => await SaveToStorage());
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));

        if (_editor.Store.GetAllShapes().Count == 0)
            CreateDemoShapes();
    }

    private void OnEditorStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task SaveToStorage()
    {
        try
        {
            var json = _editor.Store.GetSnapshot().ToJson();
            await JS.InvokeVoidAsync("localStorage.setItem", "tldraw-demo-data", json);
            _autoSaveStatus = "saved";
        }
        catch { _autoSaveStatus = "error"; }
    }

    private async Task LoadFromStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "tldraw-demo-data");
            if (!string.IsNullOrEmpty(json))
            {
                var snapshot = TLStoreSnapshot.FromJson(json);
                if (snapshot != null && snapshot.Records.Count > 0)
                {
                    _editor.Store.LoadSnapshot(snapshot);
                    _autoSaveStatus = "loaded";
                }
            }
        }
        catch { }
    }

    private async Task ExportPng()
    {
        try
        {
            var pngBytes = _editor.ExportToPng();
            if (pngBytes != null)
            {
                var base64 = Convert.ToBase64String(pngBytes);
                await JS.InvokeVoidAsync("eval",
                    $"var a=document.createElement('a');a.href='data:image/png;base64,{base64}';a.download='tldraw.png';a.click()");
                _autoSaveStatus = "PNG exported";
            }
        }
        catch { _autoSaveStatus = "PNG export failed"; }
    }

    private async Task ExportJson()
    {
        try
        {
            var json = _editor.Store.GetSnapshot().ToJson();
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", json);
            _autoSaveStatus = "JSON copied";
        }
        catch { _autoSaveStatus = "Export failed"; }
    }

    private void CreateDemoShapes()
    {
        _editor.CreateShape(ShapeType.Frame, 50, 50);
        var frame = _editor.Store.GetAllShapes().Last();
        frame.Width = 850; frame.Height = 620; frame.Index = new("a");
        if (frame.Props is TLFrameProps fp) fp.Name = "Demo Frame";

        _editor.CreateShape(ShapeType.Geo, 100, 100);
        var rect = _editor.Store.GetAllShapes().Last();
        rect.Width = 200; rect.Height = 120;
        rect.Style.Fill = new("#E3F2FD"); rect.Style.Color = new("#1565C0");
        rect.Style.BorderRadius = new(8);
        if (rect.Props is TLGeoProps rp) { rp.GeoType = GeoVariant.Rectangle; rp.Text = "Rectangle"; }

        _editor.CreateShape(ShapeType.Geo, 400, 100);
        var ellipse = _editor.Store.GetAllShapes().Last();
        ellipse.Width = 180; ellipse.Height = 120;
        ellipse.Style.Fill = new("#FCE4EC"); ellipse.Style.Color = new("#C62828");
        if (ellipse.Props is TLGeoProps ep) { ep.GeoType = GeoVariant.Ellipse; ep.Text = "Ellipse"; }

        _editor.CreateShape(ShapeType.Geo, 680, 100);
        var diamond = _editor.Store.GetAllShapes().Last();
        diamond.Width = 140; diamond.Height = 140;
        diamond.Style.Fill = new("#FFF3E0"); diamond.Style.Color = new("#E65100");
        if (diamond.Props is TLGeoProps dp) { dp.GeoType = GeoVariant.Diamond; dp.Text = "Diamond"; }

        _editor.CreateShape(ShapeType.Geo, 100, 320);
        var star = _editor.Store.GetAllShapes().Last();
        star.Width = 140; star.Height = 140;
        star.Style.Fill = new("#FFF9C4"); star.Style.Color = new("#F9A825");
        if (star.Props is TLGeoProps sp) sp.GeoType = GeoVariant.Star;

        _editor.CreateShape(ShapeType.Geo, 320, 300);
        var hex = _editor.Store.GetAllShapes().Last();
        hex.Width = 150; hex.Height = 130;
        hex.Style.Fill = new("#E8F5E9"); hex.Style.Color = new("#2E7D32");
        if (hex.Props is TLGeoProps hp) hp.GeoType = GeoVariant.Hexagon;

        _editor.CreateShape(ShapeType.Geo, 550, 300);
        var tri = _editor.Store.GetAllShapes().Last();
        tri.Width = 150; tri.Height = 130;
        tri.Style.Fill = new("#F3E5F5"); tri.Style.Color = new("#6A1B9A");
        if (tri.Props is TLGeoProps tp) tp.GeoType = GeoVariant.Triangle;

        _editor.CreateShape(ShapeType.Text, 100, 520);
        var text = _editor.Store.GetAllShapes().Last();
        if (text.Props is TLTextProps txp) { txp.Text = "Hello, tldraw!"; txp.FontSize = new(32); }
        text.Style.Color = new("#1565C0");

        _editor.CreateShape(ShapeType.Note, 400, 500);
        var note = _editor.Store.GetAllShapes().Last();
        if (note.Props is TLNoteProps np) { np.Text = "Click me to\nselect!"; np.NoteColor = new("#FFEB3B"); }

        _editor.CreateShape(ShapeType.Line, 700, 500);
        var line = _editor.Store.GetAllShapes().Last();
        line.Width = 200; line.Height = 100;
        line.Style.Color = new("#1565C0"); line.Style.StrokeWidth = new(3);
        if (line.Props is TLLineProps lp) lp.Points = new() { new(0, 0), new(100, 80), new(200, 20) };

        _editor.Invalidate();
    }

    public void Dispose()
    {
        _autoSaveTimer?.Dispose();
        _editor.StateChanged -= OnEditorStateChanged;
    }
}
